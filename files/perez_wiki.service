[Unit]
Description=Gunicorn instance to server perez.wiki
After=network.target

[Service]
User=perez-wiki
Group=www-data
WorkingDirectory=/home/perez-wiki/perez_wiki/
Environment=PATH="/home/perez-wiki/perez_wiki/venv/bin"
ExecStart=/home/perez-wiki/perez_wiki/venv/bin/gunicorn --workers 4 --bind unix:perez_wiki.sock -m 007 wsgi:gunicorn_app

[Install]
WantedBy=multi-user.target
